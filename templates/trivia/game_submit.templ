package trivia

import (
	"fmt"
	"github.com/jgoodhcg/mindmeld/internal/db"
)

templ SubmitQuestion(lobby db.Lobby, round db.TriviaRound) {
	<div class="bg-elevated border border-border rounded p-5 sm:p-6">
		<div class="text-center mb-6">
			<div class="inline-block px-4 py-2 bg-base rounded border border-border mb-3">
				<h2 class="font-mono text-lg sm:text-xl font-bold text-cyan">ROUND { fmt.Sprintf("%d", round.RoundNumber) }</h2>
			</div>
			<p class="text-text-muted text-sm">Write a question to challenge the group</p>
		</div>
		<form action={ templ.SafeURL("/lobbies/" + lobby.Code + "/trivia/questions") } method="POST" class="space-y-5">
			<input type="hidden" name="template_id" id="template_id" value=""/>
			<div>
				<label class="block font-mono text-xs tracking-widest uppercase text-text-muted mb-2">Question</label>
				<textarea
					name="question_text"
					id="question_text"
					required
					rows="3"
					placeholder="Enter your question..."
					class="w-full bg-base border border-border rounded px-4 py-3 text-text placeholder-text-muted focus:outline-none focus:border-cyan transition-colors resize-none"
				></textarea>
			</div>
			<div>
				<label class="block font-mono text-xs tracking-widest uppercase text-success mb-2">Correct Answer</label>
				<input
					type="text"
					name="correct_answer"
					id="correct_answer"
					required
					placeholder="The right answer"
					class="w-full bg-base border border-success/30 rounded px-4 py-3 text-text placeholder-text-muted focus:outline-none focus:border-success transition-colors"
				/>
			</div>
			<div class="space-y-3">
				<label class="block font-mono text-xs tracking-widest uppercase text-danger mb-2">Wrong Answers</label>
				<div class="space-y-3">
					<input
						type="text"
						name="wrong_answer_1"
						id="wrong_answer_1"
						required
						placeholder="Wrong answer 1"
						class="w-full bg-base border border-danger/20 rounded px-4 py-3 text-text placeholder-text-muted focus:outline-none focus:border-danger transition-colors"
					/>
					<input
						type="text"
						name="wrong_answer_2"
						id="wrong_answer_2"
						required
						placeholder="Wrong answer 2"
						class="w-full bg-base border border-danger/20 rounded px-4 py-3 text-text placeholder-text-muted focus:outline-none focus:border-danger transition-colors"
					/>
					<input
						type="text"
						name="wrong_answer_3"
						id="wrong_answer_3"
						required
						placeholder="Wrong answer 3"
						class="w-full bg-base border border-danger/20 rounded px-4 py-3 text-text placeholder-text-muted focus:outline-none focus:border-danger transition-colors"
					/>
				</div>
			</div>
			<details id="assist-panel" class="rounded border border-border bg-base/70">
				<summary class="cursor-pointer list-none px-4 py-3 font-mono text-xs uppercase tracking-widest text-text-muted">
					Stuck? Generate a draft question
				</summary>
				<div class="border-t border-border px-4 py-4 space-y-3">
					<p class="text-text-muted text-sm">Use this only if you need a starting point. You can edit everything before submitting.</p>
					<div class="grid sm:grid-cols-[1fr_auto] gap-2">
						<input
							type="text"
							id="assist_topic"
							placeholder="Optional topic (e.g., history, movies, tech)"
							class="w-full bg-base border border-border rounded px-4 py-2 text-text placeholder-text-muted focus:outline-none focus:border-cyan transition-colors"
						/>
						<button
							type="button"
							id="assist_generate_button"
							data-lobby-code={ lobby.Code }
							aria-describedby="assist_status"
							class="bg-base hover:bg-border border border-border text-text px-4 py-2 rounded font-mono font-bold tracking-wide transition-colors disabled:bg-border disabled:text-text-muted disabled:cursor-not-allowed"
							onclick="generateQuestionAssistFromButton(this)"
						>
							GENERATE DRAFT
						</button>
					</div>
					<p id="assist_status" aria-live="polite" class="text-xs text-text-muted min-h-4"></p>
				</div>
			</details>
			<button type="submit" class="w-full bg-amber hover:bg-amber/80 text-base py-3 rounded font-mono font-bold tracking-wide transition-colors mt-6">
				SUBMIT QUESTION
			</button>
		</form>
		<!-- Help button -->
		<div class="mt-4 text-center">
			<button
				type="button"
				id="open-templates-modal"
				aria-haspopup="dialog"
				aria-controls="templates-modal"
				aria-expanded="false"
				class="text-text-muted hover:text-cyan text-sm font-mono transition-colors"
				onclick="openTemplatesModal()"
			>
				Need help? Use a question pack
			</button>
		</div>
	</div>
	<!-- Templates Modal -->
	<div
		id="templates-modal"
		class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
		role="dialog"
		aria-modal="true"
		aria-hidden="true"
		aria-labelledby="templates-modal-title"
		aria-describedby="templates-modal-description"
	>
		<!-- Backdrop -->
		<div
			class="absolute inset-0 bg-base/80 backdrop-blur-sm"
			aria-hidden="true"
			onclick="closeTemplatesModal()"
		></div>
		<!-- Modal content -->
		<div class="relative bg-elevated border border-border rounded-lg w-full max-w-lg p-6 shadow-xl" data-modal-panel>
			<div class="flex items-center justify-between mb-4">
				<div>
					<h2 id="templates-modal-title" class="font-mono text-lg font-bold text-text">Question Packs</h2>
					<p id="templates-modal-description" class="text-sm text-text-muted mt-1">Choose a pack to fill the form with a starter question.</p>
				</div>
				<button
					type="button"
					aria-label="Close question packs dialog"
					class="text-text-muted hover:text-text transition-colors"
					onclick="closeTemplatesModal()"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>
			<div
				id="templates-container"
				hx-get={ "/lobbies/" + lobby.Code + "/trivia/question-templates" }
				hx-trigger="load"
				hx-swap="innerHTML"
			>
				<div class="text-center py-8">
					<div class="inline-block animate-spin h-6 w-6 border-2 border-cyan border-t-transparent rounded-full"></div>
					<p class="text-text-muted text-sm mt-2">Loading packs...</p>
				</div>
			</div>
		</div>
	</div>
	<script>
		let templatesModalLastFocusedElement = null;
		function getTemplatesModalElements() {
			const modal = document.getElementById('templates-modal');
			if (!modal) {
				return {};
			}
			return {
				modal,
				panel: modal.querySelector('[data-modal-panel]'),
				openButton: document.getElementById('open-templates-modal'),
				templatesContainer: document.getElementById('templates-container'),
			};
		}
		function getTemplatesModalFocusableElements() {
			const { modal } = getTemplatesModalElements();
			if (!modal || modal.classList.contains('hidden')) {
				return [];
			}
			return Array.from(modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
				.filter(function(element) {
					return !element.hasAttribute('disabled') && element.getAttribute('aria-hidden') !== 'true';
				});
		}
		function focusTemplatesModalFirstElement() {
			const focusable = getTemplatesModalFocusableElements();
			if (focusable.length > 0) {
				focusable[0].focus();
			}
		}
		function updateAssistStatus(message, tone) {
			const status = document.getElementById('assist_status');
			if (!status) {
				return;
			}
			status.textContent = message || '';
			status.classList.remove('text-text-muted', 'text-danger', 'text-success');
			if (tone === 'error') {
				status.classList.add('text-danger');
			} else if (tone === 'success') {
				status.classList.add('text-success');
			} else {
				status.classList.add('text-text-muted');
			}
		}
		function fillGeneratedQuestion(payload) {
			document.getElementById('question_text').value = payload.question_text || '';
			document.getElementById('correct_answer').value = payload.correct_answer || '';
			document.getElementById('wrong_answer_1').value = payload.wrong_answer_1 || '';
			document.getElementById('wrong_answer_2').value = payload.wrong_answer_2 || '';
			document.getElementById('wrong_answer_3').value = payload.wrong_answer_3 || '';
			document.getElementById('template_id').value = '';
		}
		function generateQuestionAssistFromButton(button) {
			if (!button || !button.dataset) {
				return;
			}
			const lobbyCode = button.dataset.lobbyCode || '';
			if (!lobbyCode) {
				updateAssistStatus('Missing lobby code for AI assist.', 'error');
				return;
			}
			generateQuestionAssist(lobbyCode);
		}
		async function generateQuestionAssist(lobbyCode) {
			const button = document.getElementById('assist_generate_button');
			const topicInput = document.getElementById('assist_topic');
			if (!button || !topicInput) {
				return;
			}
			button.disabled = true;
			updateAssistStatus('Generating question...', 'default');
			try {
				const body = new URLSearchParams();
				body.set('topic', topicInput.value || '');
				const response = await fetch(`/lobbies/${lobbyCode}/trivia/generate-question`, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/x-www-form-urlencoded',
					},
					body: body.toString(),
				});
				const data = await response.json();
				if (!response.ok) {
					throw new Error(data.error || 'Request failed');
				}
				fillGeneratedQuestion(data);
				const source = data.source === 'openai' ? 'AI model' : 'fallback generator';
				updateAssistStatus(`Draft generated from ${source}. Edit before submitting.`, 'success');
			} catch (error) {
				updateAssistStatus('Unable to generate right now. Try again or use a question pack.', 'error');
			} finally {
				button.disabled = false;
			}
		}
		function openTemplatesModal() {
			const { modal, openButton, templatesContainer } = getTemplatesModalElements();
			if (!modal) {
				return;
			}
			templatesModalLastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : openButton;
			modal.classList.remove('hidden');
			modal.setAttribute('aria-hidden', 'false');
			if (openButton) {
				openButton.setAttribute('aria-expanded', 'true');
			}
			// Trigger HTMX to reload templates (in case some were used since page load)
			if (templatesContainer) {
				htmx.trigger(templatesContainer, 'load');
			}
			window.requestAnimationFrame(focusTemplatesModalFirstElement);
		}
		function closeTemplatesModal() {
			const { modal, openButton } = getTemplatesModalElements();
			if (!modal) {
				return;
			}
			modal.classList.add('hidden');
			modal.setAttribute('aria-hidden', 'true');
			if (openButton) {
				openButton.setAttribute('aria-expanded', 'false');
			}
			if (templatesModalLastFocusedElement && typeof templatesModalLastFocusedElement.focus === 'function') {
				templatesModalLastFocusedElement.focus();
				return;
			}
			if (openButton) {
				openButton.focus();
			}
		}
		// Close modal on escape key
		document.addEventListener('keydown', function(e) {
			const { modal } = getTemplatesModalElements();
			if (!modal || modal.classList.contains('hidden')) {
				return;
			}
			if (e.key === 'Escape') {
				closeTemplatesModal();
				return;
			}
			if (e.key !== 'Tab') {
				return;
			}
			const focusable = getTemplatesModalFocusableElements();
			if (focusable.length === 0) {
				e.preventDefault();
				return;
			}
			const first = focusable[0];
			const last = focusable[focusable.length - 1];
			if (e.shiftKey && document.activeElement === first) {
				e.preventDefault();
				last.focus();
				return;
			}
			if (!e.shiftKey && document.activeElement === last) {
				e.preventDefault();
				first.focus();
			}
		});
		document.body.addEventListener('htmx:afterSwap', function(event) {
			if (!event.target || event.target.id !== 'templates-container') {
				return;
			}
			const { modal } = getTemplatesModalElements();
			if (modal && !modal.classList.contains('hidden')) {
				window.requestAnimationFrame(focusTemplatesModalFirstElement);
			}
		});
	</script>
}
